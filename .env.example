# Kassensoftware Environment Variables Template
# Kopiert diese Datei zu .env und passen Sie die Werte an

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL Verbindungsstring
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://kassensystem:kassensystem@postgres:5432/kassensystem

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Secret Key für Session-Verschlüsselung
# WICHTIG: Für Production - Generieren Sie einen neuen zufälligen Key!
# Beispiel: openssl rand -hex 32
# Minimum 32 Zeichen!
SECRET_KEY=change-this-to-a-random-secret-key-in-production-minimum-32-chars

# ============================================
# APPLICATION MODE
# ============================================
# Production-Modus (deaktiviert CORS und andere Dev-Features)
# true = Production (CORS deaktiviert)
# false oder nicht gesetzt = Development (CORS aktiv)
PRODUCTION=false

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Email-Versand aktivieren (für Z-Bon und Nachricht-Versand)
EMAIL_ENABLED=false

# Absender für automatische E-Mails
EMAIL_SENDER=noreply@kassensystem.local

# Standard-Empfänger für Z-Bon E-Mails
EMAIL_RECIPIENT_ZBON=admin@kassensystem.local

# SMTP Server (E-Mail Versand)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=

# ============================================
# AUTOMATISCHER Z-BON-VERSAND (OPTIONAL)
# ============================================
# Automatischer Z-Bon-Versand aktivieren
SCHEDULED_ZBON_ENABLED=false

# Richtig: SCHEDULED_ZBON_TIME (ohne Space!)
SCHEDULED_ZBON_TIME=23:59
# Report-Typ für automatischen Versand
# Mögliche Werte:
#   "zbon" - TSE-konformer Z-Bon (STANDARD)
#   "daily-report" - Detailliertes Tagesprotokoll
SCHEDULED_ZBON_REPORT_TYPE=zbon
